<svg xmlns="http://www.w3.org/2000/svg" width="200" height="200" viewBox="0 0 200 200">
  <rect width="200" height="200" fill="#f1f5f9"/>
  <!-- Koper Badan -->
  <rect x="40" y="80" width="120" height="80" rx="8" fill="#64748b"/>
  <!-- Koper Pegangan -->
  <path d="M 80 80 V 60 Q 80 50 100 50 Q 120 50 120 60 V 80" fill="none" stroke="#64748b" stroke-width="12" stroke-linecap="round"/>
  <!-- Koper Detail Garis -->
  <rect x="40" y="110" width="120" height="15" fill="#475569"/>
  <!-- Gembok Kecil -->
  <rect x="90" y="105" width="20" height="25" rx="3" fill="#cbd5e1"/>
</svg>
